<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="8dp">

    <!-- C -->
    <Button
        android:id="@+id/clear"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="C"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- BACKSPACE -->
    <Button
        android:id="@+id/backspace"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="⌫"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/clear"
        android:layout_marginStart="8dp"/>

    <!-- % -->
    <Button
        android:id="@+id/percent"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="%"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/backspace"
        android:layout_marginStart="8dp"/>

    <!-- ÷ -->
    <Button
        android:id="@+id/division"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="÷"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/percent"
        android:layout_marginStart="8dp"/>


    <!-- 7 -->
    <Button
        android:id="@+id/btn7"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="7"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/clear"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 8 -->
    <Button
        android:id="@+id/btn8"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="8"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/backspace"
        app:layout_constraintStart_toStartOf="@id/backspace"
        android:layout_marginTop="8dp"/>

    <!-- 9 -->
    <Button
        android:id="@+id/btn9"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="9"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/percent"
        app:layout_constraintStart_toStartOf="@id/percent"
        android:layout_marginTop="8dp"/>

    <!-- x -->
    <Button
        android:id="@+id/multiply"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="x"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toBottomOf="@id/division"
        app:layout_constraintStart_toStartOf="@id/division"
        android:layout_marginTop="8dp"/>


    <!-- 4 -->
    <Button
        android:id="@+id/btn4"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="4"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn7"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 5 -->
    <Button
        android:id="@+id/btn5"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="5"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn8"
        app:layout_constraintStart_toStartOf="@id/btn8"
        android:layout_marginTop="8dp"/>

    <!-- 6 -->
    <Button
        android:id="@+id/btn6"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="6"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn9"
        app:layout_constraintStart_toStartOf="@id/btn9"
        android:layout_marginTop="8dp"/>

    <!-- - -->
    <Button
        android:id="@+id/subtract"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="-"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toBottomOf="@id/multiply"
        app:layout_constraintStart_toStartOf="@id/multiply"
        android:layout_marginTop="8dp"/>


    <!-- 1 -->
    <Button
        android:id="@+id/btn1"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="1"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn4"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- 2 -->
    <Button
        android:id="@+id/btn2"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="2"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn5"
        app:layout_constraintStart_toStartOf="@id/btn5"
        android:layout_marginTop="8dp"/>

    <!-- 3 -->
    <Button
        android:id="@+id/btn3"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="3"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn6"
        app:layout_constraintStart_toStartOf="@id/btn6"
        android:layout_marginTop="8dp"/>

    <!-- + -->
    <Button
        android:id="@+id/add"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="+"
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#6A4C93"
        app:layout_constraintTop_toBottomOf="@id/subtract"
        app:layout_constraintStart_toStartOf="@id/subtract"
        android:layout_marginTop="8dp"/>

    <!-- 0 -->
    <Button
        android:id="@+id/btn0"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text="0"
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn1"
        app:layout_constraintStart_toStartOf="parent"
        android:layout_marginTop="8dp"/>

    <!-- . -->
    <Button
        android:id="@+id/btnPoint"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:text=","
        android:textSize="22sp"
        android:textColor="#6A4C93"
        android:backgroundTint="@color/white"
        app:strokeColor="#6A4C93"
        app:strokeWidth="3dp"
        app:layout_constraintTop_toBottomOf="@id/btn2"
        app:layout_constraintStart_toStartOf="@id/btn2"
        android:layout_marginTop="8dp"/>

    <!-- = -->
    <Button
        android:id="@+id/equal"
        android:layout_width="150dp"
        android:layout_height="70dp"
        android:text="="
        android:textSize="22sp"
        android:textColor="@color/white"
        android:backgroundTint="#00C2A8"
        app:layout_constraintTop_toBottomOf="@id/btn3"
        app:layout_constraintStart_toStartOf="@id/btn3"
        android:layout_marginTop="8dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>
