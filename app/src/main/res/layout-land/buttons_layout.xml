<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:columnCount="4"
    android:columnOrderPreserved="false"
    android:rowCount="5"
    android:layout_gravity="center">

    <!-- C -->
    <Button
        android:id="@+id/clear"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="0"
        android:layout_column="0"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/clear"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- BACKSPACE -->
    <Button
        android:id="@+id/backspace"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="0"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/backspace"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- % -->
    <Button
        android:id="@+id/percent"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="0"
        android:layout_column="2"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/percent"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- ÷ -->
    <Button
        android:id="@+id/division"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="0"
        android:layout_column="3"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/division"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- 7 -->
    <Button
        android:id="@+id/btn7"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="1"
        android:layout_column="0"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_7"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- 8 -->
    <Button
        android:id="@+id/btn8"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="1"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_8"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- 9 -->
    <Button
        android:id="@+id/btn9"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="1"
        android:layout_column="2"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_9"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- x -->
    <Button
        android:id="@+id/multiply"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="1"
        android:layout_column="3"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/multiply"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- 4 -->
    <Button
        android:id="@+id/btn4"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="2"
        android:layout_column="0"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_4"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- 5 -->
    <Button
        android:id="@+id/btn5"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="2"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_5"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- 6 -->
    <Button
        android:id="@+id/btn6"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="2"
        android:layout_column="2"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_6"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- - -->
    <Button
        android:id="@+id/subtract"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="2"
        android:layout_column="3"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/subtract"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- 1 -->
    <Button
        android:id="@+id/btn1"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="3"
        android:layout_column="0"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_1"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- 2 -->
    <Button
        android:id="@+id/btn2"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="3"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_2"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- 3 -->
    <Button
        android:id="@+id/btn3"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="3"
        android:layout_column="2"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_3"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- + -->
    <Button
        android:id="@+id/add"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="3"
        android:layout_column="3"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#6A4C93"
        android:text="@string/add"
        android:textColor="@color/white"
        android:textSize="14sp" />

    <!-- 0 -->
    <Button
        android:id="@+id/btn0"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="4"
        android:layout_column="0"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/digit_0"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- . -->
    <Button
        android:id="@+id/btnPoint"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="4"
        android:layout_column="1"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="@color/white"
        android:text="@string/point"
        android:textColor="#6A4C93"
        android:textSize="14sp"
        app:strokeColor="#6A4C93"
        app:strokeWidth="1.5dp" />

    <!-- = -->
    <Button
        android:id="@+id/equal"
        android:layout_width="0dp"
        android:layout_height="48dp"
        android:layout_row="4"
        android:layout_column="2"
        android:layout_columnSpan="2"
        android:layout_columnWeight="1"
        android:layout_margin="2dp"
        android:backgroundTint="#00C2A8"
        android:text="@string/equal"
        android:textColor="@color/white"
        android:textSize="14sp" />

</GridLayout>
